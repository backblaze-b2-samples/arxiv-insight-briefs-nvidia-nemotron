# Backblaze B2 (required)
B2_ENDPOINT=https://s3.us-west-004.backblazeb2.com
B2_REGION=us-west-004
B2_KEY_ID=
B2_APPLICATION_KEY=
B2_BUCKET_NAME=

# NVIDIA Build (free tier) — used for topic routing, abstract ranking, synthesis.
# Get a key at https://build.nvidia.com. Optional: omit to run the sample
# without LLM analysis (the brief will still archive arxiv candidates to B2).
NVIDIA_API_KEY=
NVIDIA_NEMOTRON_MODEL=mistralai/mistral-nemotron
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1

# Briefing tuning (optional — defaults shown)
ARXIV_CANDIDATE_LIMIT=50
BRIEF_PAPER_LIMIT=8
BRIEF_TIME_WINDOW_MONTHS=12
MAX_BRIEFS_IN_FLIGHT=2
MAX_PAPER_CHARS=12000

# Frontend (optional — defaults to http://localhost:8000)
# NEXT_PUBLIC_API_URL=http://localhost:8000

# Example of what filled-in values look like (fake — for visual reference only):
# B2_ENDPOINT=https://s3.us-west-004.backblazeb2.com
# B2_REGION=us-west-004
# B2_KEY_ID=00abcdef1234567000000001
# B2_APPLICATION_KEY=K001AbCdEfGhIjKlMnOpQrStUvWxYz0=
# B2_BUCKET_NAME=my-arxiv-briefs
