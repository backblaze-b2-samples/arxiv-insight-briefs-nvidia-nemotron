# Backblaze B2 (required)
B2_REGION=<region>
B2_APPLICATION_KEY_ID=
B2_APPLICATION_KEY=
B2_BUCKET_NAME=

# NVIDIA Build (free tier) — used for topic routing, abstract ranking, synthesis.
# Get a key at https://build.nvidia.com. Optional: omit to run the sample
# without LLM analysis (the brief will still archive arxiv candidates to B2).
NVIDIA_API_KEY=
NVIDIA_NEMOTRON_MODEL=mistralai/mistral-nemotron
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1

# Briefing tuning (optional — defaults shown)
ARXIV_CANDIDATE_LIMIT=50
BRIEF_PAPER_LIMIT=8
BRIEF_TIME_WINDOW_MONTHS=12
MAX_BRIEFS_IN_FLIGHT=2
MAX_PAPER_CHARS=12000

# Frontend (optional — defaults to http://localhost:8000)
# NEXT_PUBLIC_API_URL=http://localhost:8000

# Optional / advanced (defaults shown). Override only when you need to.
B2_PUBLIC_URL_BASE=https://f000.backblazeb2.com/file/<bucket-name>
OBJECT_KEY_PREFIX=arxiv-insight-briefs/
API_PORT=8000
API_CORS_ORIGINS=http://localhost:3000,http://localhost:3001
API_CORS_ORIGIN_REGEX=
PRESIGNED_TTL_SECONDS=3600

# Example of what filled-in values look like (synthetic — for visual reference only):
# B2_REGION=us-west-004
# B2_APPLICATION_KEY_ID=your-application-key-id
# B2_APPLICATION_KEY=your-application-key
# B2_BUCKET_NAME=my-arxiv-briefs
# B2_PUBLIC_URL_BASE=https://f000.backblazeb2.com/file/my-arxiv-briefs
